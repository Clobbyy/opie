#!/bin/bash
# Opie.app launcher (becomes Contents/MacOS/Opie).
#
# A .app can't run Python directly, so this thin script finds a Python whose Tk
# is >= 8.6 (the macOS *system* Python ships the deprecated Tk 8.5, which crashes
# the control panel) and runs the package bundled inside this app. No Terminal
# window appears; problems are surfaced with a native dialog.
set -u

HERE="$(cd "$(dirname "$0")" && pwd)"                 # .../Opie.app/Contents/MacOS
CODE="$(cd "$HERE/../Resources" && pwd)"              # .../Contents/Resources (holds opie/)
PYORG="https://www.python.org/downloads/macos/"

tk_ok() { "$1" -c 'import sys,tkinter; sys.exit(0 if tkinter.TkVersion>=8.6 else 1)' >/dev/null 2>&1; }

pick_python() {
  local c
  for c in \
      /Library/Frameworks/Python.framework/Versions/3.1[0-9]/bin/python3 \
      /opt/homebrew/bin/python3 \
      /opt/homebrew/bin/python3.1[0-9] \
      /usr/local/bin/python3 \
      "$(command -v python3 2>/dev/null)"; do
    [ -n "$c" ] && [ -x "$c" ] || continue
    if tk_ok "$c"; then echo "$c"; return 0; fi
  done
  return 1
}

PY="$(pick_python || true)"
if [ -z "$PY" ]; then
  # No Tk-capable Python. Show a real dialog (no Python needed) and offer python.org.
  osascript >/dev/null 2>&1 \
    -e 'set r to display dialog "Opie needs Python 3 with Tk 8.6 or newer. The macOS built-in Python uses the old Tk 8.5, which can'"'"'t run the control panel.\n\nInstall Python 3 from python.org (free), then open Opie again." with title "Opie" buttons {"Open python.org", "OK"} default button "OK" with icon caution' \
    -e 'if button returned of r is "Open python.org" then do shell script "open '"$PYORG"'"' || true
  exit 1
fi

# Make the bundled package importable and record where it lives so the relay and
# the launchd autostart agent can find it later.
export PYTHONPATH="$CODE${PYTHONPATH:+:$PYTHONPATH}"
OPIE_CODE="$CODE" "$PY" -c "import os; from opie import config; config.set_install_root(os.environ['OPIE_CODE'])" >/dev/null 2>&1 || true

exec "$PY" -m opie.gui
